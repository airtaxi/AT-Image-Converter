<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ImageConverterAT.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:ImageConverterAT.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0" Background="Transparent">
            <MenuBarItem x:Uid="FileMenu" AccessKey="F">
                <MenuFlyoutItem
                    x:Uid="FileAddMenuFlyoutItem"
                    AccessKey="O"
                    Click="OnFileAddMenuFlyoutItemClicked" />
                <MenuFlyoutItem
                    x:Name="FileStartConversionMenuFlyoutItem"
                    x:Uid="FileStartConversionMenuFlyoutItem"
                    AccessKey="C"
                    Click="OnFileStartConversionMenuFlyoutItemClicked"
                    IsEnabled="False" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Uid="FileCloseMenuFlyoutItem"
                    AccessKey="X"
                    Click="OnFileCloseMenuFlyoutItemClicked" />
            </MenuBarItem>
            <MenuBarItem x:Uid="LanguageMenu" AccessKey="L">
                <RadioMenuFlyoutItem
                    x:Name="EnglishLanguageMenuFlyoutItem"
                    x:Uid="EnglishLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    Tag="en-US" />
                <RadioMenuFlyoutItem
                    x:Name="KoreanLanguageMenuFlyoutItem"
                    x:Uid="KoreanLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    Tag="ko-KR" />
                <RadioMenuFlyoutItem
                    x:Name="JapaneseLanguageMenuFlyoutItem"
                    x:Uid="JapaneseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    Tag="ja-JP" />
                <RadioMenuFlyoutItem
                    x:Name="SimplifiedChineseLanguageMenuFlyoutItem"
                    x:Uid="SimplifiedChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    Tag="zh-Hans" />
                <RadioMenuFlyoutItem
                    x:Name="TraditionalChineseLanguageMenuFlyoutItem"
                    x:Uid="TraditionalChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    Tag="zh-Hant" />
            </MenuBarItem>
            <MenuBarItem x:Uid="HelpMenu" AccessKey="H">
                <MenuFlyoutItem
                    x:Uid="CheckForUpdatesMenuFlyoutItem"
                    AccessKey="U"
                    Click="OnCheckForUpdatesMenuFlyoutItemClicked" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Uid="OpenGitHubRepositoryMenuFlyoutItem"
                    AccessKey="G"
                    Click="OnOpenGitHubRepositoryMenuFlyoutItemClicked" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid
                Grid.RowSpan="2"
                Grid.Column="0"
                Margin="0,10,0,0"
                Padding="10,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer
                    x:Name="SettingsScrollViewer"
                    Grid.Row="0"
                    CornerRadius="5"
                    VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="10">
                        <StackPanel
                            Padding="10,3.5,10,0"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5">
                            <TextBlock x:Uid="ImagesTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid Margin="0,7.5,0,0">
                                <ListView
                                    x:Name="ImagesListView"
                                    Height="121.5"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="5"
                                    SelectedIndex="0"
                                    SelectionChanged="OnImageListViewSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:ImageFileViewModel">
                                            <TextBlock Text="{x:Bind FileName}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <Button
                                    x:Name="DropPlaceholderButton"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    AllowDrop="True"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnDropPlaceholderButtonClicked"
                                    CornerRadius="5"
                                    DragOver="OnDropPlaceholderButtonDragOver"
                                    Drop="OnDropPlaceholderButtonDrop">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="20"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE896;" />
                                        <TextBlock
                                            x:Uid="DropPlaceholder"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            IsHitTestVisible="False" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                                <AppBarButton
                                    x:Uid="AddButton"
                                    Click="OnAddImageAppBarButtonClicked"
                                    Icon="Add">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator
                                            Key="O"
                                            Invoked="OnAddImageAppBarButtonKeyboardAcceleratorInvoked"
                                            Modifiers="Control" />
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                                <AppBarButton
                                    x:Name="DeleteAppBarButton"
                                    x:Uid="DeleteButton"
                                    Click="OnDeleteImageAppBarButtonClicked"
                                    Icon="Delete"
                                    IsEnabled="False" />
                                <AppBarButton
                                    x:Uid="ClearButton"
                                    Click="OnClearImageAppBarButtonClicked"
                                    Icon="Clear"
                                    IsEnabled="{Binding ElementName=DeleteAppBarButton, Path=IsEnabled}" />
                            </CommandBar>
                        </StackPanel>
                        <StackPanel
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="FormatOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox
                                x:Name="FormatComboBox"
                                x:Uid="OutputFormatComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0"
                                SelectionChanged="OnFormatComboBoxSelectionChanged">
                                <ComboBox.Items>
                                    <x:String>JPG</x:String>
                                    <x:String>JXL</x:String>
                                    <x:String>PNG</x:String>
                                    <x:String>BMP</x:String>
                                    <x:String>WEBP</x:String>
                                    <x:String>AVIF</x:String>
                                    <x:String>ICO</x:String>
                                    <x:String>TIFF</x:String>
                                </ComboBox.Items>
                            </ComboBox>
                            <NumberBox
                                x:Name="QualityNumberBox"
                                x:Uid="QualityNumberBox"
                                HorizontalAlignment="Stretch"
                                LargeChange="10"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="10"
                                SpinButtonPlacementMode="Inline"
                                Value="80" />
                        </StackPanel>
                        <StackPanel
                            x:Name="RotationSettingsStackPanel"
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="RotationOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ToggleSwitch
                                x:Name="RotationToggleSwitch"
                                x:Uid="RotationToggleSwitch"
                                IsOn="True"
                                Toggled="OnRotationToggleSwitchToggled" />
                            <ComboBox
                                x:Name="RotationSettingsComboBox"
                                x:Uid="RotationSettingsComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="AutoRotateByExifItem" />
                                    <ComboBoxItem x:Uid="RotateClockwise90Item" />
                                    <ComboBoxItem x:Uid="RotateCounterClockwise90Item" />
                                    <ComboBoxItem x:Uid="Rotate180Item" />
                                </ComboBox.Items>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel
                            x:Name="SizeSettingsStackPanel"
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="SizeOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox
                                x:Name="SizeSettingsComboBox"
                                x:Uid="SizeSettingsComboBox"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="OnSizeSettingsComboBoxSelectionChanged">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="NoResizeItem" />
                                    <ComboBoxItem x:Uid="ResizeToFillItem" />
                                    <ComboBoxItem x:Uid="ResizeToWidthItem" />
                                    <ComboBoxItem x:Uid="ResizeToHeightItem" />
                                    <ComboBoxItem x:Uid="ResizeToCropItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <ComboBox
                                x:Name="SizeUnitComboBox"
                                x:Uid="SizeUnitComboBox"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="OnSizeUnitComboBoxSelectionChanged">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="PixelItem" />
                                    <ComboBoxItem x:Uid="PercentItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <ComboBox
                                x:Name="ResizeInterpolationComboBox"
                                x:Uid="ResizeInterpolationComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="ResizeInterpolationDefaultItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationNoneItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationBoxItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationTriangleItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationCubicItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationLanczosItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <Grid x:Name="SizeGrid" ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox
                                    x:Name="WidthNumberBox"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Header="Width"
                                    Minimum="0" />
                                <NumberBox
                                    x:Name="HeightNumberBox"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Header="Height"
                                    Minimum="0" />
                            </Grid>
                            <StackPanel
                                x:Name="CropSettingsPanel"
                                Spacing="5"
                                Visibility="Collapsed">
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        x:Name="CropHorizontalAnchorComboBox"
                                        x:Uid="CropHorizontalAnchorComboBox"
                                        HorizontalAlignment="Stretch"
                                        SelectedIndex="1">
                                        <ComboBox.Items>
                                            <ComboBoxItem x:Uid="CropHorizontalLeftItem" />
                                            <ComboBoxItem x:Uid="CropHorizontalCenterItem" />
                                            <ComboBoxItem x:Uid="CropHorizontalRightItem" />
                                        </ComboBox.Items>
                                    </ComboBox>
                                    <ComboBox
                                        x:Name="CropVerticalAnchorComboBox"
                                        x:Uid="CropVerticalAnchorComboBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        SelectedIndex="1">
                                        <ComboBox.Items>
                                            <ComboBoxItem x:Uid="CropVerticalTopItem" />
                                            <ComboBoxItem x:Uid="CropVerticalCenterItem" />
                                            <ComboBoxItem x:Uid="CropVerticalBottomItem" />
                                        </ComboBox.Items>
                                    </ComboBox>
                                </Grid>
                                <SplitButton x:Name="CropBackgroundColorSplitButton" HorizontalAlignment="Stretch">
                                    <StackPanel
                                        HorizontalAlignment="Left"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <Border
                                            x:Name="CropBackgroundColorPreviewBorder"
                                            Width="20"
                                            Height="20"
                                            Background="Transparent"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4" />
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="CropBackgroundColorTextBlock" />
                                            <TextBlock x:Name="CropBackgroundColorValueTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <SplitButton.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedLeft">
                                            <ColorPicker
                                                MinWidth="320"
                                                ColorChanged="OnCropBackgroundColorPickerColorChanged"
                                                IsAlphaEnabled="False" />
                                        </Flyout>
                                    </SplitButton.Flyout>
                                </SplitButton>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="SaveOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBox
                                x:Name="PrefixTextBox"
                                x:Uid="PrefixTextBox"
                                HorizontalAlignment="Stretch"
                                Text="ATIC_"
                                TextChanged="OnPrefixTextBoxTextChanged" />
                            <TextBox
                                x:Name="PrefixPreviewTextBox"
                                x:Uid="PrefixPreviewTextBox"
                                HorizontalAlignment="Stretch"
                                IsTabStop="False" />
                            <ToggleSwitch
                                x:Name="OverwriteFileToggleSwitch"
                                x:Uid="OverwriteFileToggleSwitch"
                                IsOn="True" />
                        </StackPanel>
                        <StackPanel
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="OutputFolderTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="SameFolderRadioButton"
                                    x:Uid="SameFolderRadioButton"
                                    Grid.Column="0"
                                    GroupName="OutputFolder"
                                    IsChecked="True" />
                                <Button
                                    x:Name="OpenSameFolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="OnOpenSameFolderButtonClicked"
                                    IsEnabled="False">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="PhotoFolderRadioButton"
                                    x:Uid="PhotoFolderRadioButton"
                                    Grid.Column="0"
                                    GroupName="OutputFolder" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="OnOpenPhotoFolderButtonClicked">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="CustomFolderRadioButton"
                                    x:Uid="CustomFolderRadioButton"
                                    Grid.Column="0"
                                    GroupName="OutputFolder" />
                                <Button
                                    x:Name="OpenCustomFolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="OnOpenCustomFolderButtonClicked"
                                    IsEnabled="False">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid Margin="28,0,0,0" ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="CustomFolderPathTextBox"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Click="OnBrowseCustomFolderButtonClicked">
                                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="SubfolderRadioButton"
                                    x:Uid="SubfolderRadioButton"
                                    Grid.Column="0"
                                    GroupName="OutputFolder" />
                                <Button
                                    x:Name="OpenSubfolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Click="OnOpenSubfolderButtonClicked"
                                    IsEnabled="False">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <TextBox
                                x:Name="SubfolderNameTextBox"
                                Margin="28,0,0,0"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="output"
                                Text="output" />
                        </StackPanel>
                        <StackPanel
                            Padding="10,3.5,10,10"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="5"
                            Spacing="5">
                            <TextBlock x:Uid="ConversionOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ToggleSwitch
                                x:Name="ParallelExecutionToggleSwitch"
                                x:Uid="ParallelExecutionToggleSwitch"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="PreserveFileDateToggleSwitch"
                                x:Uid="PreserveFileDateToggleSwitch"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="PreserveExifToggleSwitch"
                                x:Uid="PreserveExifToggleSwitch"
                                IsOn="True" />
                            <ToggleSwitch
                                x:Name="PreserveAnimationToggleSwitch"
                                x:Uid="PreserveAnimationToggleSwitch"
                                IsOn="True" />
                            <ToggleSwitch x:Name="DeleteOriginalToggleSwitch" x:Uid="DeleteOriginalToggleSwitch" />
                            <Grid ColumnSpacing="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Uid="SaveDefaultsButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Click="OnSaveDefaultsButtonClicked" />
                                <Button
                                    x:Uid="ResetDefaultsButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Click="OnResetDefaultsButtonClicked" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <Button
                    x:Name="ConvertButton"
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Click="OnConvertButtonClicked"
                    IsEnabled="False" />
            </Grid>
            <Frame x:Name="PreviewFrame" Grid.Column="1">
                <Grid
                    x:Name="PreviewGrid"
                    Margin="10"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    CornerRadius="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer
                        x:Name="PreviewScrollViewer"
                        Grid.Row="0"
                        Margin="10,10,10,0"
                        CornerRadius="5"
                        HorizontalScrollBarVisibility="Auto"
                        SizeChanged="OnPreviewScrollViewerSizeChanged"
                        VerticalScrollBarVisibility="Auto"
                        ZoomMode="Enabled">
                        <Image
                            x:Name="PreviewImage"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ImageOpened="OnImagePreviewImageOpened" />
                    </ScrollViewer>
                    <StackPanel
                        x:Name="NoPreviewStackPanel"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon
                            FontSize="48"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <TextBlock
                            x:Uid="NoPreviewText"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <CommandBar
                        Grid.Row="1"
                        Background="Transparent"
                        DefaultLabelPosition="Right">
                        <AppBarButton
                            x:Uid="ZoomInButton"
                            Click="OnZoomInAppBarButtonClicked"
                            Icon="ZoomIn" />
                        <AppBarButton
                            x:Uid="ZoomOutButton"
                            Click="OnZoomOutAppBarButtonClicked"
                            Icon="ZoomOut" />
                        <AppBarButton
                            x:Uid="ResetZoomButton"
                            Click="OnResetZoomAppBarButtonClicked"
                            Icon="Zoom" />
                    </CommandBar>
                </Grid>
            </Frame>
            <Grid
                x:Name="ProgressGrid"
                Grid.Row="1"
                Grid.Column="1"
                Margin="10,0,10,10"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                CornerRadius="5"
                Visibility="Collapsed">
                <ListView x:Name="ProgressLogListView" Height="150">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>