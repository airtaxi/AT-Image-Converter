<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ImageConverterAT.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:ImageConverterAT.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0" Background="Transparent">
            <MenuBarItem x:Uid="FileMenu" AccessKey="F">
                <MenuFlyoutItem
                    x:Uid="FileAddMenuFlyoutItem"
                    AccessKey="O"
                    Command="{x:Bind ViewModel.AddImagesCommand}" />
                <MenuFlyoutItem
                    x:Name="FileStartConversionMenuFlyoutItem"
                    x:Uid="FileStartConversionMenuFlyoutItem"
                    AccessKey="C"
                    Command="{x:Bind ViewModel.ConvertCommand}"
                    IsEnabled="{x:Bind ViewModel.IsConvertEnabled, Mode=OneWay}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Uid="FileCloseMenuFlyoutItem"
                    AccessKey="X"
                    Command="{x:Bind ViewModel.CloseCommand}" />
            </MenuBarItem>
            <MenuBarItem x:Uid="LanguageMenu" AccessKey="L">
                <RadioMenuFlyoutItem
                    x:Uid="EnglishLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsEnglishLanguageChecked, Mode=OneWay}"
                    Tag="en-US" />
                <RadioMenuFlyoutItem
                    x:Uid="KoreanLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsKoreanLanguageChecked, Mode=OneWay}"
                    Tag="ko-KR" />
                <RadioMenuFlyoutItem
                    x:Uid="JapaneseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsJapaneseLanguageChecked, Mode=OneWay}"
                    Tag="ja-JP" />
                <RadioMenuFlyoutItem
                    x:Uid="SimplifiedChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsSimplifiedChineseLanguageChecked, Mode=OneWay}"
                    Tag="zh-Hans" />
                <RadioMenuFlyoutItem
                    x:Uid="TraditionalChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsTraditionalChineseLanguageChecked, Mode=OneWay}"
                    Tag="zh-Hant" />
            </MenuBarItem>
            <MenuBarItem x:Uid="HelpMenu" AccessKey="H">
                <MenuFlyoutItem
                    x:Uid="CheckForUpdatesMenuFlyoutItem"
                    AccessKey="U"
                    Command="{x:Bind ViewModel.CheckForUpdatesCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Uid="OpenGitHubRepositoryMenuFlyoutItem"
                    AccessKey="G"
                    Command="{x:Bind ViewModel.OpenGitHubRepositoryCommand}" />
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid
                Grid.RowSpan="2"
                Grid.Column="0"
                Margin="0,8,0,0"
                Padding="8,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer
                    x:Name="SettingsScrollViewer"
                    Grid.Row="0"
                    CornerRadius="4"
                    IsEnabled="{x:Bind ViewModel.IsConverting, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    VerticalScrollBarVisibility="Hidden">
                    <StackPanel Spacing="12">
                        <StackPanel
                            Padding="8,4,8,0"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4">
                            <TextBlock x:Uid="ImagesTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid Margin="0,8,0,0">
                                <ListView
                                    x:Name="ImagesListView"
                                    Height="121.5"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    ItemsSource="{x:Bind ViewModel.ImageFileViewModels, Mode=OneWay}"
                                    SelectedIndex="0"
                                    SelectedItem="{x:Bind ViewModel.SelectedImageFile, Mode=TwoWay}"
                                    SelectionChanged="OnImageListViewSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:ImageFileViewModel">
                                            <TextBlock Text="{x:Bind FileName}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <Button
                                    x:Name="DropPlaceholderButton"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    AllowDrop="True"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="OnDropPlaceholderButtonClicked"
                                    CornerRadius="4"
                                    DragOver="OnDropPlaceholderButtonDragOver"
                                    Drop="OnDropPlaceholderButtonDrop"
                                    Visibility="{x:Bind ViewModel.IsDropPlaceholderVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <FontIcon
                                            FontSize="20"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE896;" />
                                        <TextBlock
                                            x:Uid="DropPlaceholder"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            IsHitTestVisible="False" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                                <AppBarButton
                                    x:Uid="AddButton"
                                    Command="{x:Bind ViewModel.AddImagesCommand}"
                                    Icon="Add">
                                    <AppBarButton.KeyboardAccelerators>
                                        <KeyboardAccelerator
                                            Key="O"
                                            Invoked="OnAddImageAppBarButtonKeyboardAcceleratorInvoked"
                                            Modifiers="Control" />
                                    </AppBarButton.KeyboardAccelerators>
                                </AppBarButton>
                                <AppBarButton
                                    x:Name="DeleteAppBarButton"
                                    x:Uid="DeleteButton"
                                    Command="{x:Bind ViewModel.DeleteImageCommand}"
                                    Icon="Delete"
                                    IsEnabled="{x:Bind ViewModel.IsDeleteEnabled, Mode=OneWay}" />
                                <AppBarButton
                                    x:Uid="ClearButton"
                                    Command="{x:Bind ViewModel.ClearImagesCommand}"
                                    Icon="Clear"
                                    IsEnabled="{x:Bind ViewModel.HasImages, Mode=OneWay}" />
                            </CommandBar>
                        </StackPanel>
                        <StackPanel
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8">
                            <TextBlock x:Uid="FormatOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox
                                x:Name="FormatComboBox"
                                x:Uid="OutputFormatComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.FormatIndex, Mode=TwoWay}">
                                <ComboBox.Items>
                                    <x:String>JPG</x:String>
                                    <x:String>JXL</x:String>
                                    <x:String>PNG</x:String>
                                    <x:String>BMP</x:String>
                                    <x:String>WEBP</x:String>
                                    <x:String>AVIF</x:String>
                                    <x:String>ICO</x:String>
                                    <x:String>TIFF</x:String>
                                </ComboBox.Items>
                            </ComboBox>
                            <NumberBox
                                x:Name="QualityNumberBox"
                                x:Uid="QualityNumberBox"
                                HorizontalAlignment="Stretch"
                                LargeChange="10"
                                Maximum="100"
                                Minimum="0"
                                SmallChange="10"
                                SpinButtonPlacementMode="Inline"
                                Visibility="{x:Bind ViewModel.IsQualityAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Value="{x:Bind ViewModel.Quality, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel
                            x:Name="RotationSettingsStackPanel"
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsSizeAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock x:Uid="RotationOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ToggleSwitch
                                x:Name="RotationToggleSwitch"
                                x:Uid="RotationToggleSwitch"
                                IsOn="{x:Bind ViewModel.RotationEnabled, Mode=TwoWay}" />
                            <ComboBox
                                x:Name="RotationSettingsComboBox"
                                x:Uid="RotationSettingsComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.RotationIndex, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.IsRotationSettingsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="AutoRotateByExifItem" />
                                    <ComboBoxItem x:Uid="RotateClockwise90Item" />
                                    <ComboBoxItem x:Uid="RotateCounterClockwise90Item" />
                                    <ComboBoxItem x:Uid="Rotate180Item" />
                                </ComboBox.Items>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel
                            x:Name="SizeSettingsStackPanel"
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsSizeAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock x:Uid="SizeOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox
                                x:Name="SizeSettingsComboBox"
                                x:Uid="SizeSettingsComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.SizeSettingIndex, Mode=TwoWay}">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="NoResizeItem" />
                                    <ComboBoxItem x:Uid="ResizeToFillItem" />
                                    <ComboBoxItem x:Uid="ResizeToWidthItem" />
                                    <ComboBoxItem x:Uid="ResizeToHeightItem" />
                                    <ComboBoxItem x:Uid="ResizeToCropItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <ComboBox
                                x:Name="SizeUnitComboBox"
                                x:Uid="SizeUnitComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.SizeUnitIndex, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.IsSizeUnitVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="PixelItem" />
                                    <ComboBoxItem x:Uid="PercentItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <ComboBox
                                x:Name="ResizeInterpolationComboBox"
                                x:Uid="ResizeInterpolationComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.ResizeInterpolationIndex, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.IsResizeInterpolationVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ComboBox.Items>
                                    <ComboBoxItem x:Uid="ResizeInterpolationDefaultItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationNoneItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationBoxItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationTriangleItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationCubicItem" />
                                    <ComboBoxItem x:Uid="ResizeInterpolationLanczosItem" />
                                </ComboBox.Items>
                            </ComboBox>
                            <Grid
                                x:Name="SizeGrid"
                                ColumnSpacing="8"
                                Visibility="{x:Bind ViewModel.IsSizeGridVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <NumberBox
                                    x:Name="WidthNumberBox"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Header="{x:Bind ViewModel.WidthHeader, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.IsWidthEnabled, Mode=OneWay}"
                                    Minimum="{x:Bind ViewModel.WidthMinimum, Mode=OneWay}"
                                    Value="{x:Bind ViewModel.Width, Mode=TwoWay}" />
                                <NumberBox
                                    x:Name="HeightNumberBox"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Header="{x:Bind ViewModel.HeightHeader, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.IsHeightEnabled, Mode=OneWay}"
                                    Minimum="{x:Bind ViewModel.HeightMinimum, Mode=OneWay}"
                                    Value="{x:Bind ViewModel.Height, Mode=TwoWay}" />
                            </Grid>
                            <StackPanel
                                x:Name="CropSettingsPanel"
                                Spacing="8"
                                Visibility="{x:Bind ViewModel.IsCropVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        x:Name="CropHorizontalAnchorComboBox"
                                        x:Uid="CropHorizontalAnchorComboBox"
                                        HorizontalAlignment="Stretch"
                                        SelectedIndex="{x:Bind ViewModel.CropHorizontalAnchorIndex, Mode=TwoWay}">
                                        <ComboBox.Items>
                                            <ComboBoxItem x:Uid="CropHorizontalLeftItem" />
                                            <ComboBoxItem x:Uid="CropHorizontalCenterItem" />
                                            <ComboBoxItem x:Uid="CropHorizontalRightItem" />
                                        </ComboBox.Items>
                                    </ComboBox>
                                    <ComboBox
                                        x:Name="CropVerticalAnchorComboBox"
                                        x:Uid="CropVerticalAnchorComboBox"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        SelectedIndex="{x:Bind ViewModel.CropVerticalAnchorIndex, Mode=TwoWay}">
                                        <ComboBox.Items>
                                            <ComboBoxItem x:Uid="CropVerticalTopItem" />
                                            <ComboBoxItem x:Uid="CropVerticalCenterItem" />
                                            <ComboBoxItem x:Uid="CropVerticalBottomItem" />
                                        </ComboBox.Items>
                                    </ComboBox>
                                </Grid>
                                <SplitButton x:Name="CropBackgroundColorSplitButton" HorizontalAlignment="Stretch">
                                    <StackPanel
                                        HorizontalAlignment="Left"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <Border
                                            x:Name="CropBackgroundColorPreviewBorder"
                                            Width="20"
                                            Height="20"
                                            Background="{x:Bind ViewModel.CropBackgroundColorBrush, Mode=OneWay}"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4" />
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Uid="CropBackgroundColorTextBlock" />
                                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind ViewModel.CropBackgroundColorDisplayValue, Mode=OneWay}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <SplitButton.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedLeft">
                                            <ColorPicker
                                                x:Name="CropBackgroundColorPicker"
                                                MinWidth="320"
                                                IsAlphaEnabled="{x:Bind ViewModel.OutputFormatSupportsAlpha, Mode=OneWay}"
                                                Color="{x:Bind ViewModel.CropBackgroundColor, Mode=TwoWay}" />
                                        </Flyout>
                                    </SplitButton.Flyout>
                                </SplitButton>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="8">
                            <TextBlock x:Uid="SaveOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBox
                                x:Name="PrefixTextBox"
                                x:Uid="PrefixTextBox"
                                HorizontalAlignment="Stretch"
                                Text="{x:Bind ViewModel.Prefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                x:Name="PrefixPreviewTextBox"
                                x:Uid="PrefixPreviewTextBox"
                                HorizontalAlignment="Stretch"
                                IsReadOnly="True"
                                IsTabStop="False"
                                Text="{x:Bind ViewModel.PrefixPreview, Mode=OneWay}" />
                            <ToggleSwitch
                                x:Name="OverwriteFileToggleSwitch"
                                x:Uid="OverwriteFileToggleSwitch"
                                IsOn="{x:Bind ViewModel.OverwriteFile, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="4">
                            <TextBlock
                                x:Uid="OutputFolderTitle"
                                Margin="0,0,0,4"
                                Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="SameFolderRadioButton"
                                    x:Uid="SameFolderRadioButton"
                                    Grid.Column="0"
                                    Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                    CommandParameter="SameFolder"
                                    GroupName="OutputFolder"
                                    IsChecked="{x:Bind ViewModel.IsSameFolderChecked, Mode=OneWay}" />
                                <Button
                                    x:Name="OpenSameFolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind ViewModel.OpenSameFolderCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsOpenSameFolderEnabled, Mode=OneWay}">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="PhotoFolderRadioButton"
                                    x:Uid="PhotoFolderRadioButton"
                                    Grid.Column="0"
                                    Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                    CommandParameter="PhotoFolder"
                                    GroupName="OutputFolder"
                                    IsChecked="{x:Bind ViewModel.IsPhotoFolderChecked, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind ViewModel.OpenPhotoFolderCommand}">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="CustomFolderRadioButton"
                                    x:Uid="CustomFolderRadioButton"
                                    Grid.Column="0"
                                    Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                    CommandParameter="CustomFolder"
                                    GroupName="OutputFolder"
                                    IsChecked="{x:Bind ViewModel.IsCustomFolderChecked, Mode=OneWay}" />
                                <Button
                                    x:Name="OpenCustomFolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind ViewModel.OpenCustomFolderCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsOpenCustomFolderEnabled, Mode=OneWay}">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <Grid Margin="28,0,0,0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="CustomFolderPathTextBox"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.CustomFolderPath, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Command="{x:Bind ViewModel.BrowseCustomFolderCommand}">
                                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                                </Button>
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton
                                    x:Name="SubfolderRadioButton"
                                    x:Uid="SubfolderRadioButton"
                                    Grid.Column="0"
                                    Command="{x:Bind ViewModel.SelectOutputFolderCommand}"
                                    CommandParameter="Subfolder"
                                    GroupName="OutputFolder"
                                    IsChecked="{x:Bind ViewModel.IsSubfolderChecked, Mode=OneWay}" />
                                <Button
                                    x:Name="OpenSubfolderButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Command="{x:Bind ViewModel.OpenSubfolderCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsOpenSubfolderEnabled, Mode=OneWay}">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                            <TextBox
                                x:Name="SubfolderNameTextBox"
                                Margin="28,0,0,0"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="output"
                                Text="{x:Bind ViewModel.SubfolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel
                            Padding="8,4,8,8"
                            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                            CornerRadius="4"
                            Spacing="4">
                            <TextBlock
                                x:Uid="ConversionOptionsTitle"
                                Margin="0,0,0,4"
                                Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ToggleSwitch
                                x:Name="ParallelExecutionToggleSwitch"
                                x:Uid="ParallelExecutionToggleSwitch"
                                IsOn="{x:Bind ViewModel.ParallelExecution, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Name="PreserveFileDateToggleSwitch"
                                x:Uid="PreserveFileDateToggleSwitch"
                                IsOn="{x:Bind ViewModel.PreserveFileDate, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Name="PreserveExifToggleSwitch"
                                x:Uid="PreserveExifToggleSwitch"
                                IsOn="{x:Bind ViewModel.PreserveExif, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Name="PreserveAnimationToggleSwitch"
                                x:Uid="PreserveAnimationToggleSwitch"
                                IsOn="{x:Bind ViewModel.PreserveAnimation, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Name="DeleteOriginalToggleSwitch"
                                x:Uid="DeleteOriginalToggleSwitch"
                                IsOn="{x:Bind ViewModel.DeleteOriginal, Mode=TwoWay}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Uid="SaveDefaultsButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.SaveDefaultsCommand}" />
                                <Button
                                    x:Uid="ResetDefaultsButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.ResetDefaultsCommand}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <Button
                    x:Name="ConvertButton"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ConvertCommand}"
                    Content="{x:Bind ViewModel.ConvertButtonContent, Mode=OneWay}"
                    IsEnabled="{x:Bind ViewModel.IsConvertEnabled, Mode=OneWay}" />
            </Grid>
            <Frame
                x:Name="PreviewFrame"
                Grid.Column="1"
                IsEnabled="{x:Bind ViewModel.IsConverting, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                <Grid
                    x:Name="PreviewGrid"
                    Margin="8"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    CornerRadius="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer
                        x:Name="PreviewScrollViewer"
                        Grid.Row="0"
                        Margin="8,8,8,0"
                        CornerRadius="4"
                        HorizontalScrollBarVisibility="Auto"
                        SizeChanged="OnPreviewScrollViewerSizeChanged"
                        VerticalScrollBarVisibility="Auto"
                        ZoomMode="Enabled">
                        <Image
                            x:Name="PreviewImage"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ImageOpened="OnImagePreviewImageOpened" />
                    </ScrollViewer>
                    <StackPanel
                        x:Name="NoPreviewStackPanel"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.IsNoPreviewVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <FontIcon
                            FontSize="48"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <TextBlock
                            x:Uid="NoPreviewText"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <CommandBar
                        Grid.Row="1"
                        Background="Transparent"
                        DefaultLabelPosition="Right">
                        <AppBarButton
                            x:Uid="ZoomInButton"
                            Command="{x:Bind ViewModel.ZoomInCommand}"
                            Icon="ZoomIn" />
                        <AppBarButton
                            x:Uid="ZoomOutButton"
                            Command="{x:Bind ViewModel.ZoomOutCommand}"
                            Icon="ZoomOut" />
                        <AppBarButton
                            x:Uid="ResetZoomButton"
                            Command="{x:Bind ViewModel.ResetZoomCommand}"
                            Icon="Zoom" />
                    </CommandBar>
                </Grid>
            </Frame>
            <Grid
                x:Name="ProgressGrid"
                Grid.Row="1"
                Grid.Column="1"
                Margin="8,0,8,8"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                CornerRadius="4"
                Visibility="{x:Bind ViewModel.IsProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListView
                    x:Name="ProgressLogListView"
                    Height="150"
                    ItemsSource="{x:Bind ViewModel.ProgressLog, Mode=OneWay}">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>