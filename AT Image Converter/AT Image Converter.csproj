<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
		<TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
		<RootNamespace>ImageConverterAT</RootNamespace>
		<Platforms>x86;x64;ARM64</Platforms>
		<RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
		<PublishProfile>win-$(Platform).pubxml</PublishProfile>
		<UseWinUI>true</UseWinUI>
		<DefineConstants>$(DefineConstants);DISABLE_XAML_GENERATED_MAIN</DefineConstants>
		<UseRidGraph>true</UseRidGraph>
		<EnableMsixTooling>true</EnableMsixTooling>
		<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
		<AppxPackageSigningEnabled>true</AppxPackageSigningEnabled>
		<AppxPackageSigningTimestampDigestAlgorithm>SHA256</AppxPackageSigningTimestampDigestAlgorithm>
		<PackageCertificateKeyFile>AT Image Converter_TemporaryKey.pfx</PackageCertificateKeyFile>
		<DefaultLanguage>en-US</DefaultLanguage>
		<Version>1.0.0.5</Version>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<ApplicationIcon>Assets\Icon.ico</ApplicationIcon>
		<PackageIcon>Icon.png</PackageIcon>
		<PublishAot>true</PublishAot>
		<GenerateAppInstallerFile>False</GenerateAppInstallerFile>
		<AppxAutoIncrementPackageRevision>True</AppxAutoIncrementPackageRevision>
		<GenerateTestArtifacts>True</GenerateTestArtifacts>
		<AppxBundle>Always</AppxBundle>
		<AppxBundlePlatforms>x64|arm64</AppxBundlePlatforms>
		<HoursBetweenUpdateChecks>0</HoursBetweenUpdateChecks>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
		<PackageReference Include="Magick.NET-Q16-AnyCPU" Version="14.11.1" />
		<PackageReference Include="Microsoft-WindowsAPICodePack-Shell" Version="1.1.5" />
		<PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260317003" />
		<PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.7705" />
		<Manifest Include="$(ApplicationManifest)" />
	</ItemGroup>

	<!-- Build dependency: C++ context menu DLL must be built first -->
	<ItemGroup>
	  <ProjectReference Include="..\ATICContextMenu\ATICContextMenu.vcxproj">
	    <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
	    <Private>false</Private>
	  </ProjectReference>
	</ItemGroup>

	<!-- Context menu shell extension DLL -->
	<ItemGroup Condition="'$(Platform)' == 'ARM64'">
	  <Content Include="..\ATICContextMenu\bin\$(Configuration)\ARM64\ATICContextMenu.dll" Link="ATICContextMenu.dll">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>
	<ItemGroup Condition="'$(Platform)' == 'x64'">
	  <Content Include="..\ATICContextMenu\bin\$(Configuration)\x64\ATICContextMenu.dll" Link="ATICContextMenu.dll">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>
</Project>
