<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ImageConverterAT.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewmodels="using:ImageConverterAT.ViewModels"
    Title="AT Image Converter"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>
    <Frame x:Name="FrMain">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Image
                    Width="20"
                    Height="20"
                    Margin="5,0,0,0"
                    Source="Assets/Icon.png" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Text="AT Image Converter" />
            </StackPanel>

            <Grid
                Grid.Row="1"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Margin="0,10,0,0"
                    Padding="10,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer
                        x:Name="SvSettings"
                        Grid.Row="0"
                        CornerRadius="5"
                        VerticalScrollBarVisibility="Hidden">
                        <StackPanel Spacing="10">
                            <StackPanel
                                Padding="10,3.5,10,0"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5">
                                <TextBlock x:Uid="ImagesTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <Grid Margin="0,7.5,0,0">
                                    <ListView
                                        x:Name="LvImages"
                                        Height="121.5"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="5"
                                        SelectedIndex="0"
                                        SelectionChanged="OnImageListViewSelectionChanged">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="viewmodels:ImageFileViewModel">
                                                <TextBlock Text="{x:Bind FileName}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <Button
                                        x:Name="BtDropPlaceholder"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        AllowDrop="True"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="OnDropPlaceholderButtonClicked"
                                        CornerRadius="5"
                                        DragOver="OnDropPlaceholderButtonDragOver"
                                        Drop="OnDropPlaceholderButtonDrop">
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                            <FontIcon
                                                FontSize="20"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE896;" />
                                            <TextBlock
                                                x:Uid="DropPlaceholder"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                IsHitTestVisible="False" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                                    <AppBarButton
                                        x:Uid="AddButton"
                                        Click="OnAddImageAppBarButtonClicked"
                                        Icon="Add">
                                        <AppBarButton.KeyboardAccelerators>
                                            <KeyboardAccelerator
                                                Key="O"
                                                Invoked="OnAddImageAppBarButtonKeyboardAcceleratorInvoked"
                                                Modifiers="Control" />
                                        </AppBarButton.KeyboardAccelerators>
                                    </AppBarButton>
                                    <AppBarButton
                                        x:Name="AbbDelete"
                                        x:Uid="DeleteButton"
                                        Click="OnDeleteImageAppBarButtonClicked"
                                        Icon="Delete"
                                        IsEnabled="False" />
                                    <AppBarButton
                                        x:Uid="ClearButton"
                                        Click="OnClearImageAppBarButtonClicked"
                                        Icon="Clear"
                                        IsEnabled="{Binding ElementName=AbbDelete, Path=IsEnabled}" />
                                </CommandBar>
                            </StackPanel>
                            <StackPanel
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="FormatOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <ComboBox
                                    x:Name="CbxFormat"
                                    x:Uid="OutputFormatComboBox"
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="0"
                                    SelectionChanged="OnFormatComboBoxSelectionChanged">
                                    <ComboBox.Items>
                                        <x:String>JPG</x:String>
                                        <x:String>JXL</x:String>
                                        <x:String>PNG</x:String>
                                        <x:String>BMP</x:String>
                                        <x:String>WEBP</x:String>
                                        <x:String>AVIF</x:String>
                                        <x:String>ICO</x:String>
                                        <x:String>TIFF</x:String>
                                    </ComboBox.Items>
                                </ComboBox>
                                <NumberBox
                                    x:Name="NbQuality"
                                    x:Uid="QualityNumberBox"
                                    HorizontalAlignment="Stretch"
                                    LargeChange="10"
                                    Maximum="100"
                                    Minimum="0"
                                    SmallChange="10"
                                    SpinButtonPlacementMode="Inline"
                                    Value="80" />
                            </StackPanel>
                            <StackPanel
                                x:Name="SpRotationSettings"
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="RotationOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch
                                    x:Name="TsRotation"
                                    x:Uid="RotationToggleSwitch"
                                    IsOn="True"
                                    Toggled="OnRotationToggleSwitchToggled" />
                                <ComboBox
                                    x:Name="CbxRotationSettings"
                                    x:Uid="RotationSettingsComboBox"
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="0">
                                    <ComboBox.Items>
                                        <ComboBoxItem x:Uid="AutoRotateByExifItem" />
                                        <ComboBoxItem x:Uid="RotateClockwise90Item" />
                                        <ComboBoxItem x:Uid="RotateCounterClockwise90Item" />
                                        <ComboBoxItem x:Uid="Rotate180Item" />
                                    </ComboBox.Items>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel
                                x:Name="SpSizeSettings"
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="SizeOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <ComboBox
                                    x:Name="CbxSizeSettings"
                                    x:Uid="SizeSettingsComboBox"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="OnSizeSettingsComboBoxSelectionChanged">
                                    <ComboBox.Items>
                                        <ComboBoxItem x:Uid="NoResizeItem" />
                                        <ComboBoxItem x:Uid="ResizeToFillItem" />
                                        <ComboBoxItem x:Uid="ResizeToWidthItem" />
                                        <ComboBoxItem x:Uid="ResizeToHeightItem" />
                                    </ComboBox.Items>
                                </ComboBox>
                                <ComboBox
                                    x:Name="CbxSizeUnit"
                                    x:Uid="SizeUnitComboBox"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="OnSizeUnitComboBoxSelectionChanged">
                                    <ComboBox.Items>
                                        <ComboBoxItem x:Uid="PixelItem" />
                                        <ComboBoxItem x:Uid="PercentItem" />
                                    </ComboBox.Items>
                                </ComboBox>
                                <Grid x:Name="GdSize" ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox
                                        x:Name="NbxWidth"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        Header="Width"
                                        Minimum="0" />
                                    <NumberBox
                                        x:Name="NbxHeight"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Header="Height"
                                        Minimum="0" />
                                </Grid>
                            </StackPanel>
                            <StackPanel
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="SaveOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBox
                                    x:Name="TbxPrefix"
                                    x:Uid="PrefixTextBox"
                                    HorizontalAlignment="Stretch"
                                    Text="ATIC_"
                                    TextChanged="OnPrefixTextBoxTextChanged" />
                                <TextBox
                                    x:Name="TbxPrefixPreview"
                                    x:Uid="PrefixPreviewTextBox"
                                    HorizontalAlignment="Stretch"
                                    IsTabStop="False" />
                                <ToggleSwitch
                                    x:Name="TsOverwriteFile"
                                    x:Uid="OverwriteFileToggleSwitch"
                                    IsOn="True" />
                            </StackPanel>
                            <StackPanel
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="OutputFolderTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="RbSameFolder"
                                        x:Uid="SameFolderRadioButton"
                                        Grid.Column="0"
                                        GroupName="OutputFolder"
                                        IsChecked="True" />
                                    <Button
                                        x:Name="BtOpenSameFolder"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenSameFolderButtonClicked"
                                        IsEnabled="False">
                                        <FontIcon FontSize="14" Glyph="&#xED25;" />
                                    </Button>
                                </Grid>
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="RbPhotoFolder"
                                        x:Uid="PhotoFolderRadioButton"
                                        Grid.Column="0"
                                        GroupName="OutputFolder" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenPhotoFolderButtonClicked">
                                        <FontIcon FontSize="14" Glyph="&#xED25;" />
                                    </Button>
                                </Grid>
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="RbCustomFolder"
                                        x:Uid="CustomFolderRadioButton"
                                        Grid.Column="0"
                                        GroupName="OutputFolder" />
                                    <Button
                                        x:Name="BtOpenCustomFolder"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenCustomFolderButtonClicked"
                                        IsEnabled="False">
                                        <FontIcon FontSize="14" Glyph="&#xED25;" />
                                    </Button>
                                </Grid>
                                <Grid Margin="28,0,0,0" ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="TbxCustomFolderPath"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsReadOnly="True" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Click="OnBrowseCustomFolderButtonClicked">
                                        <FontIcon FontSize="14" Glyph="&#xE712;" />
                                    </Button>
                                </Grid>
                                <Grid ColumnSpacing="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton
                                        x:Name="RbSubfolder"
                                        x:Uid="SubfolderRadioButton"
                                        Grid.Column="0"
                                        GroupName="OutputFolder" />
                                    <Button
                                        x:Name="BtOpenSubfolder"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenSubfolderButtonClicked"
                                        IsEnabled="False">
                                        <FontIcon FontSize="14" Glyph="&#xED25;" />
                                    </Button>
                                </Grid>
                                <TextBox
                                    x:Name="TbxSubfolderName"
                                    Margin="28,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="output"
                                    Text="output" />
                            </StackPanel>
                            <StackPanel
                                Padding="10,3.5,10,10"
                                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                CornerRadius="5"
                                Spacing="5">
                                <TextBlock x:Uid="ConversionOptionsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <ToggleSwitch
                                    x:Name="TsParallelExecution"
                                    x:Uid="ParallelExecutionToggleSwitch"
                                    IsOn="True" />
                                <ToggleSwitch
                                    x:Name="TsPreserveFileDate"
                                    x:Uid="PreserveFileDateToggleSwitch"
                                    IsOn="True" />
                                <ToggleSwitch
                                    x:Name="TsPreserveExif"
                                    x:Uid="PreserveExifToggleSwitch"
                                    IsOn="True" />
                                <ToggleSwitch x:Name="TsDeleteOriginal" x:Uid="DeleteOriginalToggleSwitch" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <Button
                        x:Name="BtConvert"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Stretch"
                        Click="OnConvertButtonClicked"
                        IsEnabled="False" />
                </Grid>
                <Frame x:Name="FrPreview" Grid.Column="1">
                    <Grid
                        x:Name="GdPreview"
                        Margin="10"
                        Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer
                            x:Name="SvPreview"
                            Grid.Row="0"
                            Margin="10,10,10,0"
                            CornerRadius="5"
                            HorizontalScrollBarVisibility="Auto"
                            SizeChanged="OnPreviewScrollViewerSizeChanged"
                            VerticalScrollBarVisibility="Auto"
                            ZoomMode="Enabled">
                            <Image
                                x:Name="ImgPreview"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ImageOpened="OnImagePreviewImageOpened" />
                        </ScrollViewer>
                        <CommandBar
                            Grid.Row="1"
                            Background="Transparent"
                            DefaultLabelPosition="Right">
                            <AppBarButton
                                x:Uid="ZoomInButton"
                                Click="OnZoomInAppBarButtonClicked"
                                Icon="ZoomIn" />
                            <AppBarButton
                                x:Uid="ZoomOutButton"
                                Click="OnZoomOutAppBarButtonClicked"
                                Icon="ZoomOut" />
                            <AppBarButton
                                x:Uid="ResetZoomButton"
                                Click="OnResetZoomAppBarButtonClicked"
                                Icon="Zoom" />
                        </CommandBar>
                    </Grid>
                </Frame>
                <Grid
                    x:Name="GdProgress"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="10,0,10,10"
                    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                    CornerRadius="5"
                    Visibility="Collapsed">
                    <ListView x:Name="LvProgressLog" Height="150">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>
    </Frame>
</Window>
